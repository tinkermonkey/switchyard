# =============================================================================
# Orchestrator Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control - it contains secrets!

# =============================================================================
# REQUIRED: GitHub Integration
# =============================================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx       # GitHub Personal Access Token (repo, project, admin:repo_hook)
GITHUB_ORG=your-username                     # Your GitHub username (for personal accounts) or organization name
GITHUB_DEFAULT_BRANCH=main                   # Default branch for repositories
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here  # Webhook validation secret (generate random string)

# GitHub App Authentication (Recommended - provides bot identification)
# See documentation/github_app_setup.md for complete setup guide
GITHUB_APP_ID=                                   # GitHub App ID from app settings
GITHUB_APP_INSTALLATION_ID=                      # Installation ID from installed apps
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/orchestrator-bot.pem  # Path to private key file
# OR set the private key content directly (not recommended for production):
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# =============================================================================
# REQUIRED: Claude/Anthropic Configuration
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx  # Claude API key from Anthropic Console
CLAUDE_MODEL=claude-3-5-sonnet-20241022        # Claude model to use (optional, defaults to configured)
MAX_TOKENS=100000                               # Maximum tokens per request
TEMPERATURE=0.3                                 # Model temperature (0.0-1.0)

# =============================================================================
# OPTIONAL: Additional AI Models
# =============================================================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx      # OpenAI API key (for GPT-based reviews if needed)

# =============================================================================
# Webhook Configuration
# =============================================================================
WEBHOOK_PORT=3000                               # Port for webhook server
WEBHOOK_HOST=0.0.0.0                           # Webhook server host (0.0.0.0 for Docker)

# =============================================================================
# ngrok Configuration (for development)
# =============================================================================
NGROK_AUTHTOKEN=your_ngrok_token_here          # ngrok auth token for webhook tunneling

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://redis:6379                   # Redis connection URL (redis:6379 for Docker, localhost:6379 for local)
# REDIS_PASSWORD=your_redis_password           # Redis password (if authentication enabled)

# =============================================================================
# MCP Server Configuration
# =============================================================================
CONTEXT7_MCP_URL=https://mcp.context7.com/mcp  # Context7 SaaS MCP endpoint (for library documentation)
CONTEXT7_API_KEY=your_context7_api_key_here    # Context7 API key (optional, for rate limits)
SERENA_MCP_URL=http://serena-mcp:3001          # Serena MCP server URL (for local codebase analysis)
PUPPETEER_MCP_URL=http://puppeteer-mcp:3002    # Puppeteer MCP server URL (for web automation)

# =============================================================================
# Project Paths (for non-Docker deployments)
# =============================================================================
# WORKSPACE_ROOT=/Users/yourusername/development # Root directory for workspace projects
# ORCHESTRATOR_ROOT=/path/to/orchestrator        # Orchestrator installation directory

# =============================================================================
# Monitoring and Logging
# =============================================================================
METRICS_PORT=8000                              # Port for metrics endpoint
LOG_LEVEL=INFO                                 # Logging level (DEBUG, INFO, WARNING, ERROR)

# =============================================================================
# Host User/Group Configuration (for file permissions)
# =============================================================================
# These are auto-detected on Linux. On macOS, defaults are usually correct.
# Only override if you have permission issues with mounted volumes.
HOST_UID=1000                                  # Host user ID (run `id -u`)
HOST_GID=1000                                  # Host group ID (run `id -g`)
DOCKER_GID=0                                   # Docker group ID (run `getent group docker | cut -d: -f3` on Linux, use 0 on macOS)

# =============================================================================
# Optional Overrides
# =============================================================================
# PROJECT_PATH_OVERRIDE=/custom/path/to/projects    # Custom project path
# ORCHESTRATOR_DATA_PATH=/custom/orchestrator_data  # Custom data directory

# =============================================================================
# Production Settings (uncomment for production)
# =============================================================================
# ENVIRONMENT=production                       # Environment identifier
# SENTRY_DSN=https://xxx@sentry.io/xxx        # Sentry error tracking
# SLACK_WEBHOOK_URL=https://hooks.slack.com/  # Slack notifications