# Claude Code Orchestrator Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# GitHub Configuration
GITHUB_ORG=your-github-org

# GitHub App Authentication (Recommended - provides bot identification)
# See documentation/github_app_setup.md for complete setup guide
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/path/to/orchestrator-bot.pem
# OR set the private key content directly (not recommended for production):
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Personal Access Token (Fallback - used if GitHub App not configured)
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_PROJECTS=project-a,project-b

# Claude Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================

# Context7 MCP Server (for library documentation)
CONTEXT7_MCP_URL=http://localhost:3001
CONTEXT7_API_KEY=your-context7-api-key

# Serena MCP Server (for codebase analysis)
SERENA_MCP_URL=http://localhost:3002

# Puppeteer MCP Server (for browser automation)
PUPPETEER_MCP_URL=http://localhost:3003

# =============================================================================
# INFRASTRUCTURE CONFIGURATION
# =============================================================================

# Redis Configuration (optional - falls back to in-memory if not available)
REDIS_HOST=localhost
REDIS_PORT=6379

# Metrics and Monitoring
METRICS_PORT=9090

# =============================================================================
# PROJECT CONFIGURATION
# =============================================================================

# Default project workspace
WORKSPACE_DIR=/workspace

# State management directory
STATE_DIR=./orchestrator_data/state

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# DOCKER CONFIGURATION (for production deployment)
# =============================================================================

# Docker network name
DOCKER_NETWORK=clauditoreum-network

# Container prefix
CONTAINER_PREFIX=clauditoreum