# local state tracking (these are ephemeral and user-specific)
state/
config/projects/

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
*.egg-info/
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp

# Secrets (use environment variables instead)
config/secrets.yaml
config/projects.yaml
config/*.key
config/*.pem

# Temporary files
tmp/
temp/
*.tmp
*.backup

# Apple!!!
.DS_Store

